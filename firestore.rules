rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    // Real (non-anonymous) accounts provision their Firestore user doc under
    // their own auth uid (see src/App.tsx), so this is a reliable identity check.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    // --- Entity Specific Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.email is string && data.email.size() <= 150
        && (data.role == 'admin' || data.role == 'member');
    }

    function isValidDocumentItem(data) {
      return data.keys().hasAll(['name', 'displayName', 'cat'])
        && data.name is string && data.name.size() <= 300
        && data.displayName is string && data.displayName.size() <= 300
        && (data.cat == 'staff' || data.cat == 'programs' || data.cat == 'brand');
    }

    function isValidPost(data) {
      return data.keys().hasAll(['author', 'cat', 'text', 'date', 'authorId'])
        && data.author is string && data.author.size() <= 150
        && data.authorId is string && data.authorId.size() <= 150
        && (data.cat == 'Announcement' || data.cat == 'Kudos' || data.cat == 'Update' || data.cat == 'Question')
        && data.text is string && data.text.size() <= 10000
        && data.date is string && data.date.size() <= 100;
    }

    function isValidStory(data) {
      return data.keys().hasAll(['title', 'program', 'author', 'authorId', 'hasConsent', 'consentType'])
        && data.title is string && data.title.size() <= 300
        && data.program is string && data.program.size() <= 150
        && data.author is string && data.author.size() <= 150
        && data.authorId is string && data.authorId.size() <= 150
        && data.hasConsent is bool
        && data.consentType is string;
    }

    // --- Collection Matching Blocks ---

    // 1. Users Collection
    // userId is always the owning account's own auth uid for non-anonymous
    // accounts (see src/App.tsx provisioning), so we can use it for ownership.
    match /users/{userId} {
      allow read: if true;
      allow create: if isValidUser(incoming())
        && ((request.auth.uid == userId && incoming().role == 'member') || isAdmin());
      allow update: if isValidUser(incoming())
        && (
          (request.auth.uid == userId
            && incoming().email == resource.data.email
            && incoming().role == resource.data.role)
          || isAdmin()
        );
      allow delete: if isAdmin();
    }

    // 2. Docs (Resources) Collection — admin-managed only
    match /docs/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && docId.size() <= 200 && isValidDocumentItem(incoming());
      allow delete: if isAdmin();
    }

    // 3. Posts Collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if postId.size() <= 200
        && isValidPost(incoming())
        && isOwner(incoming().authorId);
      allow update: if isValidPost(incoming())
        && incoming().authorId == resource.data.authorId
        && (isOwner(resource.data.authorId) || isAdmin());
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // 4. Stories Collection
    match /stories/{storyId} {
      allow read: if true;
      allow create: if storyId.size() <= 200
        && isValidStory(incoming())
        && isOwner(incoming().authorId);
      allow update: if isValidStory(incoming())
        && incoming().authorId == resource.data.authorId
        && (isOwner(resource.data.authorId) || isAdmin());
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // 5. Interview Prompts Collection (admin-managed)
    match /prompts/{promptId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 6. Photos Collection
    match /photos/{photoId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incoming().keys().hasAll(['url', 'uploadedBy', 'uploadedById', 'date'])
        && incoming().url is string;
      allow delete: if isAdmin() || isSignedIn();
    }

    // 7. Calendar Events Collection
    // Admins fully manage events. Members may submit a pending event
    // request scoped to their own uid; only admins can approve (update)
    // or remove any event.
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin()
        || (eventId.size() <= 200
            && incoming().status == 'pending'
            && incoming().submittedBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
