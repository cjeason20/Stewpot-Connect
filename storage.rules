rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Real accounts provision their Firestore user doc under their own auth
    // uid (see src/App.tsx); anonymous sessions never get one, so this also
    // doubles as an "is a real signed-in account" check.
    function isSignedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Resource docs — admin-managed only, matching firestore.rules.
    match /docs/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin()
                   && request.resource.size < 20 * 1024 * 1024; // 20MB max
    }

    // Profile photos — only the owning account may upload to its own folder.
    match /photos/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    // Story photos and audio recordings
    match /story-photos/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.resource.size < 10 * 1024 * 1024;
    }
    match /story-audio/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.resource.size < 100 * 1024 * 1024; // 100MB for audio
    }

    // Community post photos
    match /post-photos/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    // Signed consent waivers (PNG images from signature pad)
    match /waivers/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
