rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Any authenticated user can upload to docs/ (admin panel enforces login)
    match /docs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024; // 20MB max
    }

    // Profile photos — any authenticated user may upload (app uses anonymous auth,
    // so auth.uid does not match the Firestore user document id)
    match /photos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
